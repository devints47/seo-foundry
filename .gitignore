# --------------------------------------------------------
# Ignore lockfiles and node_modules inside packages/*
# but still allow submodule tracking
# --------------------------------------------------------

# Ignore everything inside packages/
packages/*

# But allow git to track submodule pointers
!packages/**/.git

# Optionally ignore other generated files inside submodules
packages/**/dist/
packages/**/node_modules/
packages/**/package-lock.json
packages/**/pnpm-lock.yaml

# --------------------------------------------------------
# Ignore compiled files
# --------------------------------------------------------
*.tsbuildinfo
